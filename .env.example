# ── Required ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# Generate these once by running: node -e "const wp=require('web-push'); const k=wp.generateVAPIDKeys(); console.log(k)"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=tannerbrock.web@gmail.com

# ── Optional ──────────────────────────────────────────────────────────────────
PORT=3000
# Comma-separated allowed origins (leave * for dev, set your Railway URL for prod)
ALLOWED_ORIGIN=*
# SQLite file location (Railway uses /app/data.db by default via volume)
DB_PATH=/app/data.db
